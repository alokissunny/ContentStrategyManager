{
  "name": "bauhly-backoffice-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Internal backoffice API — competitor register, collection and analysis",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --experimental-strip-types src/server.ts",
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev:memory": "tsx src/scripts/devServer.ts",
    "create:admin": "tsx src/scripts/createAdmin.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.5",
    "@types/bcryptjs": "^2.4.6",
    "apify-client": "^2.11.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.0",
    "morgan": "^1.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^24.13.2",
    "mongodb-memory-server": "^10.4.3",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2",
    "vitest": "^4.1.10"
  }
}
