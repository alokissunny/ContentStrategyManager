PORT=5290
# Shared with the customer API so the backoffice can join to User/customer records.
MONGO_URI=mongodb://127.0.0.1:27017/widesignals
# Must match the customer API's secret only if you want tokens to interoperate;
# otherwise use a distinct secret so backoffice sessions are independent.
JWT_SECRET=change-this-backoffice-secret
JWT_EXPIRES_IN=12h
# Origin of the backoffice UI (Vite dev server).
CLIENT_URL=http://localhost:5190

# Apify (Instagram collection) - https://console.apify.com/account/integrations
APIFY_TOKEN=
APIFY_INSTAGRAM_PROFILE_ACTOR=apify/instagram-profile-scraper
APIFY_INSTAGRAM_POST_ACTOR=apify/instagram-post-scraper
# Posts pulled per account per collection run.
COLLECTION_POSTS_PER_ACCOUNT=40
# How many accounts to collect in parallel (Apify rate-limits).
COLLECTION_CONCURRENCY=3
# When an account is first added, backfill this many days of its posts.
COLLECTION_BACKFILL_DAYS=30
# Posts requested per backfill. The scraper returns the N most recent and the
# date window is applied after, so this caps how far back the window can reach.
COLLECTION_BACKFILL_POSTS=90

# Claude — used for register-wide competitor analysis (Overview → Run analysis)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
