PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/widesignals
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Google OAuth - https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Admin seed (npm run seed:admin) - creates or promotes an admin account.
# Admins can connect more than one Instagram handle.
ADMIN_EMAIL=admin@widesignals.com
ADMIN_PASSWORD=admin-password-1234
ADMIN_NAME=Admin

# Apify (Instagram scraping) - https://console.apify.com/account/integrations
APIFY_TOKEN=
APIFY_INSTAGRAM_PROFILE_ACTOR=apify/instagram-profile-scraper
APIFY_INSTAGRAM_POST_ACTOR=apify/instagram-post-scraper
INSTAGRAM_POSTS_LIMIT=12

# Competitor discovery: real accounts are found via hashtag search, then scraped
# for live follower counts. COMPETITOR_HASHTAG_RESULTS = posts scanned to collect
# accounts; COMPETITOR_MAX_CANDIDATES = accounts scraped + ranked per search.
APIFY_INSTAGRAM_HASHTAG_ACTOR=apify/instagram-hashtag-scraper
COMPETITOR_HASHTAG_RESULTS=60
COMPETITOR_MAX_CANDIDATES=18

# Anthropic (brand DNA analysis + competitor discovery) - https://console.anthropic.com
# COMPETITOR_MODEL only picks hashtags and ranks the real accounts found by the
# hashtag search — it never invents handles — so a low-cost model works well.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
COMPETITOR_MODEL=claude-haiku-4-5-20251001

# AWS S3 (brand analysis report storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REPORT_PRESIGN_EXPIRY_SECONDS=3600
