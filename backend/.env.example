PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/widesignals
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Google OAuth - https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Admin seed (npm run seed:admin) - creates or promotes an admin account.
# Admins can connect more than one Instagram handle.
ADMIN_EMAIL=admin@widesignals.com
ADMIN_PASSWORD=admin-password-1234
ADMIN_NAME=Admin

# Apify (Instagram scraping) - https://console.apify.com/account/integrations
APIFY_TOKEN=
APIFY_INSTAGRAM_PROFILE_ACTOR=apify/instagram-profile-scraper
APIFY_INSTAGRAM_POST_ACTOR=apify/instagram-post-scraper
INSTAGRAM_POSTS_LIMIT=12

# Anthropic (brand DNA analysis + competitor discovery) - https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Competitor discovery model. It only picks hashtags and ranks the real accounts
# found by the hashtag search — it never invents handles — so a cheaper model is
# fine. COMPETITOR_PROVIDER selects the SDK: 'openai' (default) or 'anthropic'.
# Set COMPETITOR_MODEL to the exact provider model id.
COMPETITOR_PROVIDER=openai
COMPETITOR_MODEL=gpt-5.6-terra

# OpenAI (competitor discovery when COMPETITOR_PROVIDER=openai) - https://platform.openai.com/api-keys
OPENAI_API_KEY=

# AWS S3 (brand analysis report storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REPORT_PRESIGN_EXPIRY_SECONDS=3600
